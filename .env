# Telegram Bot Configuration
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin User IDs (comma separated)
ADMIN_IDS=12345678

# Server Configuration
PORT=3000
NODE_ENV=production
BASE_URL=https://your-railway-app.up.railway.app

# Database Configuration
DB_PATH=./bingo.db

# Game Defaults
DEFAULT_BALANCE=1000
DEFAULT_CARD_PRICE=10
DEFAULT_PRIZE=2000
MAX_CARDS_PER_BUY=10
MAX_CARD_NUMBER=999
MIN_CARD_NUMBER=100

# Telebirr Configuration
TELEBIRR_APP_ID=your_app_id_here
TELEBIRR_APP_KEY=your_app_key_here
TELEBIRR_SHORT_CODE=your_short_code_here
TELEBIRR_PUBLIC_KEY=your_public_key_here
TELEBIRR_RETURN_URL=${BASE_URL}/payment/success
TELEBIRR_NOTIFY_URL=${BASE_URL}/payment/notify
TELEBIRR_ENVIRONMENT=test

# Game Types Available
GAME_TYPES=full house,1 row,1 column,4 corners,x shape,random